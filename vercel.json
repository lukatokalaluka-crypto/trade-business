{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static-build",
      "config": { 
        "distDir": "dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": { 
        "includeFiles": ["backend/views/**"]
      }
    }
  ],
  "routes": [
    { 
      "src": "/api/(.*)", 
      "dest": "backend/server.js" 
    },
    { 
      "src": "/admin/(.*)", 
      "dest": "backend/server.js"  
    },
    { 
      "src": "/(.*)", 
      "dest": "frontend/dist/index.html" 
    }
  ]
}
